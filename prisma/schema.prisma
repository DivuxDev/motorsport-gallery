generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Album {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String   @default("")
  coverUrl    String?
  published   Boolean  @default(false)
  eventDate   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  photos      Photo[]
}

model Photo {
  id        String   @id @default(uuid())
  filename  String
  fullUrl   String
  thumbUrl  String
  width     Int
  height    Int
  size      Int
  albumId   String
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model SliderImage {
  id        String   @id @default(uuid())
  filename  String
  url       String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
